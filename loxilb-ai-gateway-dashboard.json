      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(loxilb_ai_requests_total{model=~\"$model\", tenant=~\"$tenant\"}[1m])) by (model)",
